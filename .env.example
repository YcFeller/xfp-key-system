# 复制本文件为 .env 并填写真实值。切勿将 .env 提交到版本库。

# ---------- 数据库（必填）----------
DB_HOST=localhost
DB_DATABASE=your_database
DB_USERNAME=your_user
DB_PASSWORD=your_password

# ---------- 邮件 SMTP（发验证码、重置密码等，未配置时发信将失败）----------
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=XFP密钥系统

# ---------- 定时任务：爱发电订单同步脚本（afd_orderlist_update.php）----------
# Web 调用示例：https://你的域名/app/afd_orderlist_update.php?secret=此处值
# CLI 调用示例：php app/afd_orderlist_update.php 此处值
CRON_SECRET=
